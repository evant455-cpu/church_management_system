# Copy this file to .env and fill in real values for your machine.
# .env is gitignored -- never commit real secrets.

# Django
DJANGO_SECRET_KEY=changeme-generate-a-real-one-see-README
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database -- matches docker-compose.yml's db service.
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://church_dev:church_dev_password@localhost:5432/church_management_system

# Stripe -- test-mode keys from https://dashboard.stripe.com/test/apikeys.
# STRIPE_PRICE_ID is the single-tier subscription Price you create once
# in test mode. STRIPE_WEBHOOK_SECRET comes from `stripe listen` (Stripe
# CLI) for local webhook testing, or the Dashboard once deployed.
# STRIPE_PUBLISHABLE_KEY is the matching publishable key for Stripe
# Elements (the signup wizard's card field) -- safe to expose client-side.
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_PUBLISHABLE_KEY=pk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme
STRIPE_PRICE_ID=price_changeme
# How long the free trial is, in days, for new signups (signup wizard, Phase 5).
STRIPE_TRIAL_PERIOD_DAYS=14
